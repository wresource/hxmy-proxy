    <!-- Onboarding -->
    <string name="ob_skip">Skip</string>
    <string name="ob_next">Next</string>
    <string name="ob1_title">Share this phone\'s connection with nearby devices</string>
    <string name="ob1_body">hxmy proxy lets computers, tablets and other phones on the same Wi-Fi use this phone\'s connection — including any VPN it\'s on. Think of this phone as a relay: other devices connect to it and go out the same way.</string>
    <string name="ob2_title">What it\'s for</string>
    <string name="ob2_c1_title">📺 One VPN, shared by all</string>
    <string name="ob2_c1_body">Already have a working VPN on your phone? No need to set it up on every device — let them borrow it.</string>
    <string name="ob2_c2_title">💻 For devices that can\'t install a VPN</string>
    <string name="ob2_c2_body">Work laptops, smart TVs, consoles — connect to this phone and use its network.</string>
    <string name="ob2_c3_title">🏨 Temporary networks</string>
    <string name="ob2_c3_body">Travel or hotels: when only one device is online, turn it into the gateway for the rest.</string>
    <string name="ob3_title">Just three steps</string>
    <string name="ob3_s1_title">Same Wi-Fi</string>
    <string name="ob3_s1_body">Put this phone and the other device on the same network (a hotspot works too).</string>
    <string name="ob3_s2_title">Tap “Start sharing”</string>
    <string name="ob3_s2_body">The app gives you an address like 192.168.x.x:1080, or the friendlier hxmyproxy.local.</string>
    <string name="ob3_s3_title">Enter it on the other device</string>
    <string name="ob3_s3_body">Put it in the other device\'s proxy settings. The Help page shows how for each platform.</string>
    <string name="ob3_footer">Once set, that device shares this phone\'s connection — VPN included.</string>
    <string name="ob5_title">One quick permission first</string>
    <string name="ob5_body">So nearby devices can find and connect to this phone, the system will ask for “local network” access — letting this phone be visible to others on your Wi-Fi.</string>
    <string name="ob5_privacy">🔒 It only works on your Wi-Fi — it never touches the internet or uploads anything.</string>
    <string name="ob5_allow">OK, allow</string>
    <string name="ob5_later">Maybe later</string>

    <!-- Why choose -->
    <string name="why_title">Why hxmy proxy</string>
    <string name="why1_title">🔒 Your data stays on your phone</string>
    <string name="why1_body">No connection data leaves your phone — no account, no phone-home. It only works on your Wi-Fi.</string>
    <string name="why2_title">🚫 No ads, no hidden fees</string>
    <string name="why2_body">A clean app — no banners, no pop-ups, no “upgrade to Pro”.</string>
    <string name="why3_title">🌍 Your VPN, shared automatically</string>
    <string name="why3_body">Other devices automatically follow the VPN already running on your phone — no per-device setup.</string>
    <string name="why4_title">📱 Keeps up with the latest Android (17)</string>
    <string name="why4_body">Built for the latest Android 17 — permissions and background handling done right, for steadier connections.</string>
    <string name="why5_title">🛠 Open source, fully transparent</string>
    <string name="why5_body">What it does and doesn\'t do is all in the open source code, for anyone to verify.</string>

    <!-- Help -->
    <string name="help_open">Help &amp; FAQ</string>
    <string name="replay_onboarding">Replay intro</string>
    <string name="help_title">Help</string>
    <string name="help_a_title">What is this (30s)</string>
    <string name="help_a_body">hxmy proxy shares this phone\'s connection with other devices on the same Wi-Fi. They enter one address and go online through this phone — VPN included. Fully local, no cloud, no ads, open source.</string>
    <string name="help_b_title">FAQ</string>
    <string name="faq_q1">What is a proxy? Do I need to be techie?</string>
    <string name="faq_a1">No. Think of it as “device A goes online on behalf of device B”. Just start it here and enter the address on the other device.</string>
    <string name="faq_q2">Is it safe? Will it steal my data?</string>
    <string name="faq_a2">It doesn\'t go online, upload, or collect anything, and the code is public. It only bridges devices on your own Wi-Fi.</string>
    <string name="faq_q3">hxmyproxy.local vs the numeric address?</string>
    <string name="faq_a3">Both work. .local is easier to remember; the numeric address is the fallback — if a device can\'t resolve .local (Windows or some routers), use the numbers, which always work.</string>
    <string name="faq_q4">HTTP, SOCKS5 or PAC?</string>
    <string name="faq_a4">If unsure, use HTTP — most universal. SOCKS5 for broader support. PAC is for advanced auto-routing; beginners can ignore it.</string>
    <string name="faq_q5">Will other devices really use my phone\'s VPN?</string>
    <string name="faq_a5">Yes. They use this phone\'s current network exit — if the phone is on a VPN, they go through it too.</string>
    <string name="faq_q6">Should I set a password?</string>
    <string name="faq_a6">Off by default for convenience. On public or office Wi-Fi, enable a username/password in Settings so only people you tell can connect.</string>
    <string name="help_c_title">Connect each device</string>
    <string name="plat_win_title">Windows</string>
    <string name="plat_win_body">Settings → Network &amp; Internet → Proxy → Manual setup; enter the address (hxmyproxy.local or the numbers) and port, save.</string>
    <string name="plat_mac_title">Mac</string>
    <string name="plat_mac_body">System Settings → Network → your Wi-Fi → Details → Proxies; tick “Web Proxy (HTTP)” (or SOCKS), enter address and port.</string>
    <string name="plat_ios_title">iPhone / iPad</string>
    <string name="plat_ios_body">Settings → Wi-Fi → ⓘ next to your network → Configure Proxy → Manual; enter server and port. Or use “Scan to set up” on the home screen.</string>
    <string name="plat_android_title">Android phone / tablet</string>
    <string name="plat_android_body">Settings → Wi-Fi → long-press your network → Modify → Advanced → Proxy: Manual; enter hostname and port, save.</string>
    <string name="plat_browser_title">Browser only</string>
    <string name="plat_browser_body">To route only the browser: use a proxy extension, or enable PAC and use “Scan to set up” to get a PAC URL for the “use setup script” field.</string>
    <string name="help_d_title">Can\'t connect? Troubleshooting</string>
    <string name="help_d_body">1) Make sure both devices are on the same Wi-Fi (most common cause). 2) If hxmyproxy.local fails, use the numeric address. 3) Double-check address, port and type. 4) Check the sharing notification is still active — if dismissed, sharing stopped. 5) Asked for a password? Authentication is on — check Settings. 6) Everything dropped? The phone\'s VPN may be down; with default protection, sharing stops automatically. 7) Still stuck? Open the Diagnostics page to see which step failed.</string>
    <string name="help_e_title">About · Privacy · Open source</string>
    <string name="help_e_body">hxmy proxy is an open-source, free, ad-free local tool. No data collection, no phone-home, no account. All your connections stay on your local Wi-Fi — we can\'t see or store them.</string>
</resources>
